          {
            "name": "key.majorKey",
            "description": "used as a partition key, good candidate is accountId, if empty - data replicated in all partitions",
            "in": "query",
            "required": false,
            "type": "string",
            "format": "byte"
          },
          {
            "name": "key.regionName",
            "in": "query",
            "required": false,
            "type": "string",
            "format": "byte"
          },
          {
            "name": "key.minorKey",
            "description": "used as a record key in the partition",
            "in": "query",
            "required": false,
            "type": "string",
            "format": "byte"
          },
          {
            "name": "key.timestamp.mostSigBits",
            "in": "query",
            "required": false,
            "type": "string",
            "format": "int64"
          },
          {
            "name": "key.timestamp.leastSigBits",
            "in": "query",
            "required": false,
            "type": "string",
            "format": "int64"
          },
          {
            "name": "headOnly",
            "in": "query",
            "required": false,
            "type": "boolean"
          },
          {
            "name": "timeout",
            "description": "SLA of the operation if not 0",
            "in": "query",
            "required": false,
            "type": "integer",
            "format": "int32"
          }
        ],
        "tags": [
          "KeyValueService"
        ]
      }
    },

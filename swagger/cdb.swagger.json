          "200": {
            "description": "A successful response.",
            "schema": {
              "$ref": "#/definitions/cdbStatus"
            }
          },
          "default": {
            "description": "An unexpected error response.",
            "schema": {
              "$ref": "#/definitions/googleRpcStatus"
            }
          }
        },
        "parameters": [
          {
            "name": "body",
            "in": "body",
            "required": true,
            "schema": {
              "$ref": "#/definitions/cdbBatchRequest"
            }
          }
        ],
        "tags": [
          "KeyValueService"
        ]
      }
    },
    "/v1/get": {

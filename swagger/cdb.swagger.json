  "definitions": {
    "cdbBatchRequest": {
      "type": "object",
      "properties": {
        "records": {
          "type": "array",
          "items": {
            "type": "object",
            "$ref": "#/definitions/cdbRecordRequest"
          },
          "title": "written all-or-nothing in one engine txn"
        },
        "timeout": {
          "type": "integer",
          "format": "int32",
          "title": "SLA of the operation if not 0"
        }
      }
    },
    "cdbBlock": {
      "type": "object",
      "properties": {
        "record": {
          "type": "array",
          "items": {
            "type": "object",
            "$ref": "#/definitions/cdbRecord"
          }
        }
      }
    },
    "cdbHead": {
      "type": "object",
      "properties": {
        "version": {
          "type": "string",
          "format": "uint64"
        },
        "expiresAt": {
          "type": "string",
          "format": "uint64"
        },
        "diskSize": {
          "type": "string",
          "format": "int64"
        },
        "metadata": {
          "type": "integer",
          "format": "int32",
          "title": "for user 8 bits only, 9 bit deletedBit"
        }
      }
    },
    "cdbIncrementRequest": {
      "type": "object",
      "properties": {
        "key": {
          "$ref": "#/definitions/cdbKey"
        },
        "initial": {
          "type": "string",
          "format": "int64",
          "title": "counter start value when the key is absent"
        },
        "delta": {
          "type": "string",
          "format": "int64",
          "title": "amount to add (may be negative)"
        },
        "ttlSeconds": {
          "type": "string",
          "format": "int64",
          "title": "client input: relative TTL in seconds, 0 means no TTL"
        },
        "timeout": {
          "type": "integer",
          "format": "int32",
          "title": "SLA of the operation if not 0"
        },
        "expiresAt": {
          "type": "string",
          "format": "int64",
          "description": "Absolute expiry (unix seconds) computed once on the leader; see RecordRequest."
        }
      }
    },
    "cdbIncrementResponse": {
      "type": "object",
      "properties": {
        "previous": {
          "type": "string",
          "format": "int64",
          "title": "counter value before delta was applied"
        },
        "current": {
          "type": "string",
          "format": "int64",
          "title": "counter value after delta was applied"
        },
        "version": {
          "type": "string",
          "format": "uint64",
          "title": "envelope version (raft log index on the replicated path)"
        }
      }
    },
    "cdbKey": {
      "type": "object",
      "properties": {
        "majorKey": {
          "type": "string",
          "format": "byte",
          "title": "used as a partition key, good candidate is accountId, if empty - data replicated in all partitions"
        },
        "regionName": {
          "type": "string",
          "format": "byte"
        },
        "minorKey": {
          "type": "string",
          "format": "byte",
          "title": "used as a record key in the partition"
        },
        "timestamp": {
          "$ref": "#/definitions/cdbTimeUUID",
          "title": "timestamp in TimeUUID if present"
        }
      }
    },
    "cdbRangeType": {
      "type": "string",
      "enum": [
        "LESS_OR_EQUAL"
      ],
      "default": "LESS_OR_EQUAL"
    },
    "cdbRecord": {
      "type": "object",
      "properties": {
        "key": {
          "$ref": "#/definitions/cdbKey"
        },
        "head": {
          "$ref": "#/definitions/cdbHead",
          "title": "if exists, then record was found"
        },
        "value": {
          "type": "string",
          "format": "byte"
        }
      }
    },
    "cdbRecordRequest": {
      "type": "object",
      "properties": {
        "key": {
          "$ref": "#/definitions/cdbKey"
        },
        "value": {
          "type": "string",
          "format": "byte"
        },
        "metadata": {
          "type": "integer",
          "format": "int32",
          "title": "for user 8 bits only, 9 bit deletedBit"
        },
        "ttlSeconds": {
          "type": "string",
          "format": "int64",
          "title": "client input: relative TTL in seconds, 0 means no TTL"
        },
        "compareAndSet": {
          "type": "boolean"
        },
        "version": {
          "type": "string",
          "format": "uint64",
          "title": "if 0 then putIfAbsent"
        },
        "timeout": {
          "type": "integer",
          "format": "int32",
          "title": "SLA of the operation if not 0"
        },
        "expiresAt": {
          "type": "string",
          "format": "int64",
          "description": "Absolute expiry (unix seconds) computed once on the leader from ttlSeconds\nbefore the write enters the raft log, so every replica stores the same\nexpiry. Clients leave it 0 and set ttlSeconds; the server fills it in."
        }
      }
    },
    "cdbStatus": {
      "type": "object",
      "properties": {
        "updated": {
          "type": "boolean"
        }

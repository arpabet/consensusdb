  "definitions": {
    "bbBlockMode": {
      "type": "string",
      "enum": [
        "MODE_NO",
        "MODE_GCM",
        "MODE_CFB"
      ],
      "default": "MODE_NO"
    },
    "bbBlockSize": {
      "type": "string",
      "enum": [
        "BIT_NO",
        "BIT_128",
        "BIT_192",
        "BIT_256"
      ],
      "default": "BIT_NO"
    },
    "bbCipher": {
      "type": "string",
      "enum": [
        "CIPHER_NO",
        "CIPHER_AES"
      ],
      "default": "CIPHER_NO"
    },
    "bbCompression": {
      "type": "object",
      "properties": {
        "compressor": {
          "$ref": "#/definitions/bbCompressor"
        },
        "level": {
          "$ref": "#/definitions/bbCompressionLevel"
        },
        "threshold": {
          "type": "integer",
          "format": "int64"
        }
      }
    },
    "bbCompressionLevel": {

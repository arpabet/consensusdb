          "type": "boolean",
          "format": "boolean"
        },
        "encryptOnServer": {
          "type": "boolean",
          "format": "boolean"
        },
        "ttlSeconds": {
          "type": "integer",
          "format": "int64"
        },
        "compareAndSet": {
          "type": "boolean",
          "format": "boolean"
        },
        "version": {
          "type": "string",
          "format": "uint64"
        }
      }
    },
    "cdbRangeOperation": {
      "type": "object",
      "properties": {

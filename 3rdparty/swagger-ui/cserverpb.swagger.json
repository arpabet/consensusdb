          "type": "integer",
          "format": "int64"
        }
      }
    },
    "cdbHead": {
      "type": "object",
      "properties": {
        "version": {
          "type": "string",
          "format": "uint64"
        },
        "expiresAt": {
          "type": "string",
          "format": "uint64"
        },
        "timestamp": {
          "type": "string",
          "format": "uint64"
        },
        "diskSize": {
          "type": "string",
          "format": "int64"
        }
      }
    },
    "cdbKey": {

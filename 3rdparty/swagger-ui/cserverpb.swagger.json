      "type": "object"
    },
    "cdbStatusCode": {
      "type": "string",
      "enum": [
        "SUCCESS",
        "SUCCESS_NOT_UPDATED",
        "ERROR_NO_REGION",
        "ERROR_BAD_REQUEST",
        "ERROR_POLICY",
        "ERROR_MIGRATION",
        "ERROR_NETWORK",
        "ERROR_AUTH",
        "ERROR_FORBIDDEN",
        "ERROR_TIMEOUT",
        "ERROR_OVERLOAD",
        "ERROR_OVERFLOW",
        "ERROR_LOCKED",
        "ERROR_ABORTED",
        "ERROR_INTERRUPTED",
        "ERROR_UNSUPPORTED",
        "ERROR_DRIVER",
        "ERROR_IO",
        "ERROR_INTERNAL"

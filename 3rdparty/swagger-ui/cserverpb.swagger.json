{
  "swagger": "2.0",
  "info": {
    "title": "ConsensusDB",
    "version": "1.0",
    "contact": {
      "name": "ConsensusDB",
      "url": "https://github.com/consensusdb/consensusdb",
      "email": "alex@shvid.com"
    }
  },
  "schemes": [
    "http",
    "https"
  ],
  "consumes": [
    "application/json",
    "application/octet-stream"
  ],
  "produces": [
    "application/json",
    "application/octet-stream"
  ],
  "paths": {
    "/v1/transaction": {
      "put": {
        "operationId": "Execute",
        "responses": {
          "200": {
            "description": "",
            "schema": {
              "$ref": "#/definitions/cdbTransactionResult"
            }
          }
        },
        "parameters": [
          {
            "name": "body",
            "in": "body",
            "required": true,
            "schema": {
              "$ref": "#/definitions/cdbTransaction"
            }
          }
        ],
        "tags": [
          "KeyValueService"
        ]
      }
    }
  },
  "definitions": {
    "cdbGetOperation": {
      "type": "object",
      "properties": {
        "headOnly": {
          "type": "boolean",
          "format": "boolean"
        },
        "lessOrEqualRecords": {
          "type": "integer",
          "format": "int64"
        }
      }
    },
    "cdbHead": {
      "type": "object",
      "properties": {
        "version": {
          "type": "string",
          "format": "uint64"
        },
        "expiresAt": {
          "type": "string",
          "format": "uint64"
        },
        "timestamp": {
          "$ref": "#/definitions/cdbTimeUUID"
        },
        "diskSize": {
          "type": "string",
          "format": "int64"
        }
      }
    },
    "cdbKey": {
      "type": "object",
      "properties": {
        "majorKey": {
          "type": "string",
          "format": "byte"
        },
        "regionName": {
          "type": "string",
          "format": "byte"
        },
        "minorKey": {
          "type": "string",
          "format": "byte"
        },
        "timestamp": {
          "$ref": "#/definitions/cdbTimeUUID"
        }
      }
    },
    "cdbPutOperation": {
      "type": "object",
      "properties": {
        "value": {
          "type": "string",
          "format": "byte"
        },
        "compressOnServer": {
          "type": "boolean",
          "format": "boolean"
        },
        "encryptOnServer": {
          "type": "boolean",
          "format": "boolean"
        },
        "ttlSeconds": {
          "type": "integer",
          "format": "int64"
        },
        "compareAndSet": {
          "type": "boolean",
          "format": "boolean"
        },
        "version": {
          "type": "string",
          "format": "uint64"
        }
      }
    },
    "cdbRangeOperation": {
      "type": "object",
      "properties": {
        "headOnly": {
          "type": "boolean",
          "format": "boolean"
        },
        "endMinorKey": {
          "type": "string",
          "format": "byte"
        }
      }
    },
    "cdbRecord": {
      "type": "object",
      "properties": {
        "head": {
          "$ref": "#/definitions/cdbHead"
        },
        "value": {
          "type": "string",
          "format": "byte"
        }
      }
    },
    "cdbRemoveOperation": {
      "type": "object"
    },
    "cdbStatusCode": {
      "type": "string",
      "enum": [
        "SUCCESS",
        "SUCCESS_NOT_UPDATED",
        "ERROR_NO_REGION",
        "ERROR_BAD_REQUEST",
        "ERROR_POLICY",
        "ERROR_MIGRATION",
        "ERROR_NETWORK",
        "ERROR_AUTH",
        "ERROR_FORBIDDEN",
        "ERROR_TIMEOUT",
        "ERROR_OVERLOAD",
        "ERROR_OVERFLOW",
        "ERROR_LOCKED",
        "ERROR_ABORTED",
        "ERROR_INTERRUPTED",
        "ERROR_UNSUPPORTED",
        "ERROR_DRIVER",
        "ERROR_IO",
        "ERROR_INTERNAL"
      ],
      "default": "SUCCESS"
    },
    "cdbTimeUUID": {
      "type": "object",
      "properties": {
        "mostSigBits": {
          "type": "string",
          "format": "int64"
        },
        "leastSigBits": {
          "type": "string",
          "format": "int64"
        }
      },
      "title": "Java compatible"
    },
    "cdbTouchOperation": {
      "type": "object",
      "properties": {
        "ttlSeconds": {
          "type": "integer",
          "format": "int64"
        }
      }
    },
    "cdbTransaction": {
      "type": "object",
      "properties": {
        "operations": {
          "type": "array",
          "items": {
            "$ref": "#/definitions/cdbTxOperation"
          }
        }
      }
    },
    "cdbTransactionResult": {
      "type": "object",
      "properties": {
        "results": {
          "type": "array",
          "items": {
            "$ref": "#/definitions/cdbTxOperationResult"
          }
        }
      }
    },
    "cdbTxOperation": {
      "type": "object",
      "properties": {
        "key": {
          "$ref": "#/definitions/cdbKey"
        },
        "get": {
          "$ref": "#/definitions/cdbGetOperation"
        },
        "range": {
          "$ref": "#/definitions/cdbRangeOperation"
        },
        "touch": {
          "$ref": "#/definitions/cdbTouchOperation"
        },
        "put": {
          "$ref": "#/definitions/cdbPutOperation"
        },
        "remove": {
          "$ref": "#/definitions/cdbRemoveOperation"
        }
      }
    },
    "cdbTxOperationResult": {
      "type": "object",
      "properties": {
        "status": {
          "$ref": "#/definitions/cdbStatusCode"
        },
        "message": {
          "type": "string"
        },
        "records": {
          "type": "array",
          "items": {
            "$ref": "#/definitions/cdbRecord"
          }
        }
      }
    }
  }
}


consensusdb
consensusdb.exe

pkg/webui/bindata.go

# Runtime state (project-local, like gazile): the default ./data store and the
# settings file the node writes on first run. The committed consensus.yaml sample
# is a different name and is kept.
/data/
/demo-data/
/consensusdb.yaml

# Node / webapp build artifacts (the embedded pkg/webui/bindata.go IS committed).
webapp/node_modules/
webapp/dist/

# Test binary, build with `go test -c`
*.test

# Output of the go coverage tool, specifically when used with LiteIDE
*.out

# Project-local glide cache, RE: https://github.com/Masterminds/glide/issues/736
.glide/

bin/

.idea/
tmp/

# Terraform (infra/): provider cache and state are local/remote, never committed.
# The provider lock file (.terraform.lock.hcl) IS committed.
**/.terraform/*
*.tfstate
*.tfstate.*
.terraform.tfstate.lock.info
crash.log
crash.*.log

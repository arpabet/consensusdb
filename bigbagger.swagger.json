  "paths": {
    "/v1/dataset": {
      "post": {
        "operationId": "Create",
        "responses": {
          "200": {
            "description": "",
            "schema": {
              "$ref": "#/definitions/protobufEmpty"
            }
          }
        },
        "parameters": [
          {
            "name": "body",
            "in": "body",
            "required": true,
            "schema": {
              "$ref": "#/definitions/bbDataset"
            }
          }
        ],
        "tags": [
          "DatasetService"
        ]
      }
    },
    "/v1/dataset/{name}": {
      "put": {
        "operationId": "Update",
        "responses": {
          "200": {
            "description": "",
            "schema": {
              "$ref": "#/definitions/protobufEmpty"
            }
          }
        },
        "parameters": [
          {
            "name": "name",
            "in": "path",
            "required": true,
            "type": "string"
          },
          {
            "name": "body",
            "in": "body",
            "required": true,
            "schema": {
              "$ref": "#/definitions/bbDataset"
            }
          }
        ],
        "tags": [
          "DatasetService"
        ]
      }
    },
    "/v1/dataset/{value}": {
      "get": {
        "operationId": "Get",
        "responses": {
          "200": {
            "description": "(streaming responses)",
            "schema": {

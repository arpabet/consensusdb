  "definitions": {
    "bbCompression": {
      "type": "object",
      "properties": {
        "comp": {
          "$ref": "#/definitions/bbDataCompression"
        },
        "threshold": {
          "type": "integer",
          "format": "int32"
        }
      }
    },
    "bbDataCompression": {
      "type": "string",
      "enum": [
        "DC_NO",
        "DC_FLATE",
        "DC_GZIP",
        "DC_LZW",
        "DC_ZLIB",
        "DC_BZIP2"
      ],
      "default": "DC_NO"
    },
    "bbDataDistribution": {
      "type": "string",
      "enum": [
        "DD_LOCAL",
        "DD_REPLICATION",
        "DD_PARTITION"
      ],
      "default": "DD_LOCAL"
    },
    "bbDataset": {
      "type": "object",
      "properties": {
        "version": {
          "type": "string"
        },
        "name": {
          "type": "string"
        },
        "distr": {
          "$ref": "#/definitions/bbDataDistribution"
        },
        "partition": {
          "$ref": "#/definitions/bbPartition"
        },
        "compression": {
          "$ref": "#/definitions/bbCompression"
        },
        "encryption": {
          "$ref": "#/definitions/bbEncryption"
        },
        "pit": {
          "$ref": "#/definitions/bbPointInTime"
        },
        "ttlSeconds": {
          "type": "integer",
          "format": "int32"
        }
      }
    },
    "bbEncryption": {
      "type": "object",
      "properties": {
        "algorithm": {
          "$ref": "#/definitions/bbEncryptionAlgorithm"
        },
        "mode": {
          "$ref": "#/definitions/bbEncryptionMode"
        },
        "topoKey": {
          "type": "string"
        },
        "topoIv": {
          "type": "string"
        }
      }
    },
    "bbEncryptionAlgorithm": {
      "type": "string",
      "enum": [
        "ALG_NO",
        "ALG_AES256"
      ],
      "default": "ALG_NO"
    },
    "bbEncryptionMode": {
      "type": "string",
      "enum": [
        "MODE_NO",
        "MODE_ECB",
        "MODE_CBC",
        "MODE_OFB",
        "MODE_CFB",
        "MODE_CTR",
        "MODE_XTS"
      ],
      "default": "MODE_NO"
    },
    "bbExistsOperation": {
      "type": "object"
    },
    "bbExistsResult": {
      "type": "object",
      "properties": {
        "exists": {
          "type": "boolean",
          "format": "boolean"
        },
        "timestamp": {
          "type": "string",
          "format": "uint64"
        }
      }
    },
    "bbGetOperation": {
      "type": "object"
    },
    "bbGetResult": {
      "type": "object",
      "properties": {
        "version": {
          "type": "string",
          "format": "int64"
        },
        "value": {
          "type": "string",
          "format": "byte"
        },
        "timestamp": {
          "type": "string",
          "format": "uint64"
        }
      }
    },
    "bbKey": {
      "type": "object",
      "properties": {
        "setName": {
          "type": "string"
        },
        "partitionKey": {
          "type": "string",
          "format": "byte"
        },
        "recordKey": {
          "type": "string",
          "format": "byte"
        },
        "timestamp": {
          "type": "string",
          "format": "uint64"
        }
      }
    },
    "bbPartition": {
      "type": "object",
      "properties": {
        "total": {
          "type": "integer",
          "format": "int32"
        },
        "replicationFactor": {
          "type": "integer",
          "format": "int32"
        }
      }
    },
    "bbPointInTime": {
      "type": "string",
      "enum": [
        "PIT_NO",
        "PIT_LAST_ONE",
        "PIT_LAST_FIVE",
        "PIT_LAST_TEN",
        "PIT_FIRST_TEN_LAST_TEN",
        "PIT_ALL"
      ],
      "default": "PIT_NO"
    },
    "bbPutOperation": {
      "type": "object",
      "properties": {
        "compareAndSet": {
          "type": "boolean",
          "format": "boolean"
        },
        "version": {
          "type": "string",
          "format": "int64"
        },
        "value": {
          "type": "string",
          "format": "byte"
        },
        "ttlSeconds": {
          "type": "integer",
          "format": "int32"
        }
      }
    },
    "bbPutResult": {
      "type": "object"
    },
    "bbRecordOperation": {
      "type": "object",
      "properties": {
        "key": {
          "$ref": "#/definitions/bbKey"
        },
        "exists": {
          "$ref": "#/definitions/bbExistsOperation"
        },
        "get": {
          "$ref": "#/definitions/bbGetOperation"
        },
        "touch": {
          "$ref": "#/definitions/bbTouchOperation"
        },
        "put": {
          "$ref": "#/definitions/bbPutOperation"
        },
        "remove": {
          "$ref": "#/definitions/bbRemoveOperation"
        }
      }
    },
    "bbRecordResult": {
      "type": "object",
      "properties": {
        "status": {
          "$ref": "#/definitions/bbStatusCode"
        },
        "message": {
          "type": "string"
        },
        "exists": {
          "$ref": "#/definitions/bbExistsResult"
        },
        "get": {
          "$ref": "#/definitions/bbGetResult"
        },
        "touch": {
          "$ref": "#/definitions/bbTouchResult"
        },
        "put": {
          "$ref": "#/definitions/bbPutResult"
        },
        "remove": {
          "$ref": "#/definitions/bbRemoveResult"
        }
      }
    },
    "bbRemoveOperation": {
      "type": "object"
    },
    "bbRemoveResult": {
      "type": "object"
    },
    "bbStatusCode": {
      "type": "string",
      "enum": [
        "SUCCESS",
        "SUCCESS_NOT_UPDATED",
        "ERROR_NO_DATASET",
        "ERROR_BAD_REQUEST",
        "ERROR_POLICY",
        "ERROR_MIGRATION",
        "ERROR_NETWORK",
        "ERROR_AUTH",
        "ERROR_FORBIDDEN",
        "ERROR_TIMEOUT",
        "ERROR_OVERLOAD",
        "ERROR_OVERFLOW",
        "ERROR_LOCKED",
        "ERROR_ABORTED",
        "ERROR_INTERRUPTED",
        "ERROR_UNSUPPORTED",
        "ERROR_DRIVER",
        "ERROR_IO",
        "ERROR_INTERNAL"
      ],
      "default": "SUCCESS"
    },
    "bbTouchOperation": {
      "type": "object"
    },
    "bbTouchResult": {
      "type": "object"
    },
    "bbTransaction": {
      "type": "object",
      "properties": {
        "operations": {
          "type": "array",
          "items": {
            "$ref": "#/definitions/bbRecordOperation"
          }
        }
      }
    },
    "bbTransactionContext": {
      "type": "object",
      "properties": {
        "results": {
          "type": "array",
          "items": {
            "$ref": "#/definitions/bbRecordResult"
          }
        }
      }
    },
    "protobufEmpty": {
      "type": "object",
      "description": "service Foo {\n      rpc Bar(google.protobuf.Empty) returns (google.protobuf.Empty);\n    }\n\nThe JSON representation for `Empty` is empty JSON object `{}`.",
      "title": "A generic empty message that you can re-use to avoid defining duplicated\nempty messages in your APIs. A typical example is to use it as the request\nor the response type of an API method. For instance:"
    }
  }
}
